{
  "name": "mytsproject",
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env ASYNC_TRANSPORT=rabbitmq ts-node src/presentation/http/server.ts",
    "start": "cross-env ASYNC_TRANSPORT=rabbitmq ts-node src/presentation/http/server.ts",
    "test": "cross-env NODE_ENV=test ASYNC_TRANSPORT=inmemory jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test ASYNC_TRANSPORT=inmemory jest --watch",
    "test:unit": "cross-env NODE_ENV=test ASYNC_TRANSPORT=inmemory jest tests/unit --runInBand",
    "test:integration": "cross-env NODE_ENV=test ASYNC_TRANSPORT=inmemory jest tests/integration --runInBand",
    "test:users": "cross-env NODE_ENV=test ASYNC_TRANSPORT=inmemory jest tests/api/users.e2e.test.ts --runInBand"
   },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
